# .env.example – CyberlsonShield Environment Configuration
# =====================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# .env is for local development only.
# In production, set these as environment variables directly.

# ── Flask Core ────────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CyberlsonShield"_2026_Local_Dev_Key!404@x!
# Set to 'production' for production deployments
FLASK_ENV=development

# NEVER set this to 'true' in production
FLASK_DEBUG=false

# ── Server ───────────────────────────────────────────────
PORT=5000

# ── Gunicorn (production) ────────────────────────────────
GUNICORN_WORKERS=4
