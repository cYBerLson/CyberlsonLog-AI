# .gitignore – CyberlsonLog AI
# ========================
# CRITICAL: Never commit secrets, uploads, or virtual environments.

# Environment & Secrets
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual Environment
venv/
env/
.venv/
ENV/

# Uploads & Reports (user data – never commit)
uploads/
reports/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log
